# Funwall environment example
# Copy to .env.local for local development. Never commit real secrets.

# -----------------------------------------------------------------------------
# Supabase (required for real auth/db; optional for contract/unit tests)
# When missing, Supabase client factories throw a clear configuration error.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Never expose to the browser or client bundles.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Media search providers (editor media workstream)
# Openverse is the primary free-media path. Credentials stay server-side.
# -----------------------------------------------------------------------------
OPENVERSE_CLIENT_ID=
OPENVERSE_CLIENT_SECRET=
# Optional: used only if OPENVERSE_* alone is insufficient for your deployment.
OPENVERSE_API_BASE_URL=https://api.openverse.org/v1

# Optional secondary stock provider. Leave blank to disable.
PEXELS_API_KEY=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Public site origin used in share links and absolute redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000
